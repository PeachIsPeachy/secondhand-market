# Copy to .env.local (do not commit .env.local). Restart `npm run dev` after changes.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Use ONE of these from Supabase → Project Settings → API (anon public JWT or publishable key):
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Site URL for links inside transactional emails (message alerts). Also set SITE_URL on Netlify if needed.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: notify recipients by email when they receive a marketplace message (server-only).
# SUPABASE_SERVICE_ROLE_KEY — Settings → API → service_role (never expose to the browser).
# RESEND_API_KEY / RESEND_FROM — https://resend.com
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
RESEND_FROM="ReListed <onboarding@resend.dev>"
